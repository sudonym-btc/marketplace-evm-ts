{
  "name": "@sudonym-btc/marketplace-evm",
  "version": "0.1.0",
  "description": "Nostr-agnostic EVM escrow validation, swaps, and account-abstraction engine for marketplace payments.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudonym-btc/marketplace-evm-ts.git"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./aa": {
      "types": "./dist/aa/index.d.ts",
      "import": "./dist/aa/index.js"
    },
    "./boltz": {
      "types": "./dist/boltz/index.d.ts",
      "import": "./dist/boltz/index.js"
    },
    "./auction": {
      "types": "./dist/auction/index.d.ts",
      "import": "./dist/auction/index.js"
    },
    "./escrow": {
      "types": "./dist/escrow/index.d.ts",
      "import": "./dist/escrow/index.js"
    },
    "./discovery": {
      "types": "./dist/discovery/index.d.ts",
      "import": "./dist/discovery/index.js"
    },
    "./seed": {
      "types": "./dist/seed.d.ts",
      "import": "./dist/seed.js"
    },
    "./swaps": {
      "types": "./dist/swaps/index.d.ts",
      "import": "./dist/swaps/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate:boltz-openapi": "node scripts/generate-boltz-openapi.mjs",
    "check": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "test:integration": "node --test --test-concurrency=1 test/integration/*.test.mjs"
  },
  "dependencies": {
    "@sudonym-btc/marketplace-evm-contracts": "file:../marketplace-evm-contracts",
    "boltz-core": "^5.0.0",
    "openapi-fetch": "^0.17.0",
    "ox": "0.11.3",
    "permissionless": "0.3.5",
    "viem": "2.44.4"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
